FROM oven/bun:latest

# Install system deps
USER root
RUN apt-get update && apt-get install -y curl git && rm -rf /var/lib/apt/lists/*

# Install Node.js (needed for some CLIs)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && apt-get install -y nodejs

# Install Claude Code
RUN npm install -g @anthropic-ai/claude-code

# Install Codex
RUN npm install -g @openai/codex

# Install Cursor agent CLI
RUN curl -fsSL https://cursor.com/install | bash || true

# Copy harnessctl source
WORKDIR /app
COPY . /app

# Make sure PATH includes local bins
ENV PATH="/root/.local/bin:${PATH}"

# Create harnessctl config dir
RUN bun run src/cli.ts setup 2>/dev/null || true

ENTRYPOINT ["/bin/bash"]
