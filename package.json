{
  "name": "harnessctl",
  "version": "0.1.7",
  "description": "Universal CLI wrapper for coding agents",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "harnessctl": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile src/cli.ts --outfile harnessctl",
    "bundle": "bun build src/cli.ts --outdir dist --target node --format esm && node -e \"const f='dist/cli.js';let c=require('fs').readFileSync(f,'utf8');c=c.replace(/^#!.*\\n(\\/\\/ @bun\\n)?/,'#!/usr/bin/env node\\n');require('fs').writeFileSync(f,c)\"",
    "prepublishOnly": "bun run bundle"
  },
  "keywords": [
    "cli",
    "coding-agent",
    "claude",
    "codex",
    "opencode",
    "ai",
    "developer-tools"
  ],
  "author": "mnvsk97",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnvsk97/harnessctl.git"
  },
  "homepage": "https://github.com/mnvsk97/harnessctl",
  "bugs": {
    "url": "https://github.com/mnvsk97/harnessctl/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yaml": "^2.7.1"
  }
}
